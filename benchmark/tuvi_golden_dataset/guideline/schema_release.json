{
  "description": "Release schema for Golden Dataset QA",
  "type": "object",
  "required": [
    "id",
    "chart_id",
    "birth_info",
    "chart_repr",
    "question",
    "question_complexity",
    "gold_answer",
    "expected_answer_summary",
    "gold_context_spans",
    "gold_chunk_ids",
    "required_entities",
    "labels"
  ],
  "properties": {
    "id": { "type": "string" },
    "chart_id": { "type": "string" },
    "birth_info": {
      "type": "object",
      "properties": {
        "date_solar": { "type": "string" },
        "time": { "type": "string" },
        "timezone": { "type": "string" },
        "gender": { "type": "string" }
      }
    },
    "chart_repr": { "type": "object" },
    "question": { "type": "string" },
    "question_complexity": { "enum": ["Direct", "One-hop", "Two-hop"] },
    "gold_answer": { "type": "string" },
    "expected_answer_summary": { "type": "string" },
    "gold_context_spans": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "doc_id": { "type": "string" },
          "section_id": { "type": "string" },
          "span_id": { "type": "string" },
          "page_pdf": { "type": "integer" },
          "page_book": { "type": "integer" },
          "quote": { "type": "string" }
        }
      }
    },
    "gold_chunk_ids": { "type": "array", "items": { "type": "string" } },
    "required_entities": { "type": "array", "items": { "type": "string" } },
    "labels": { "type": "object" }
  }
}