# Backend environment variables (example)
DATABASE_URL=postgres://user:password@localhost:5432/dbname
# Preferred for embedding/retrieval scripts; comma-separated and never committed with real keys.
GEMINI_API_KEYS=
# Backward-compatible fallback. GEMINI_API_KEY_2 is optional.
GEMINI_API_KEY=
GEMINI_API_KEY_2=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Neo4j
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=

# LangFuse
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=
